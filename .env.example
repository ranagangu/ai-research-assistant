# General Project Settings
PROJECT_NAME="AI Research Assistant"
SECRET_KEY="replace-this-with-a-very-secure-random-key"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database and Storage Configs
DATABASE_URL="sqlite:///./research_assistant.db"
CHROMA_DB_DIR="./chroma_db"
UPLOAD_DIR="./uploads"

# AI Model Configuration
# Supported providers: openrouter
DEFAULT_LLM_PROVIDER="openrouter" 
DEFAULT_LLM_MODEL="meta-llama/llama-3-8b-instruct:free"
DEFAULT_EMBEDDING_PROVIDER="openrouter"
DEFAULT_EMBEDDING_MODEL="openai/text-embedding-3-small"

# API Keys (Provide at least one)
OPENROUTER_API_KEY="api-key"
